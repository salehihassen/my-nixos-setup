  fileSystems."/nix" =
    { device = "/dev/mapper/cryptnix";
      fsType = "btrfs";
      options = [ "subvol=@nix" ];
    };

  fileSystems."/var/log" =
    { device = "/dev/mapper/cryptnix";
      fsType = "btrfs";
      options = [ "subvol=@log" ];
    };

  fileSystems."/.snapshots" =
    { device = "/dev/mapper/cryptnix";
      fsType = "btrfs";
      options = [ "subvol=@snapshots" ];
